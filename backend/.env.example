# Serveur
PORT=5000
NODE_ENV=development

# MongoDB Atlas — créer un compte gratuit sur cloud.mongodb.com
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/sendipay

# JWT — mettre une longue chaîne aléatoire
JWT_SECRET=remplacer_par_une_chaine_aleatoire_longue
JWT_EXPIRES_IN=7d

# Exchange Rate API — clé gratuite sur exchangerate-api.com
EXCHANGE_RATE_API_KEY=votre_cle_ici

# Email pour les alertes (compte Gmail)
EMAIL_USER=votre@gmail.com
EMAIL_PASS=mot_de_passe_application_gmail

# URL du frontend (pour CORS)
FRONTEND_URL=http://localhost:5173
